{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hello-python",
	"main": "src/entry.py",
	"compatibility_date": "2025-11-02",
	"compatibility_flags": [
		"python_workers"
	],
	"observability": {
		"enabled": true
	},
	"vars": {
		"ZULIP_EMAIL": "rules-bot@secureblue.zulipchat.com",
		"ZULIP_SITE": "https://secureblue.zulipchat.com"
	}
}
